    <title>Lucastaço Memory Game ⚽</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700&display=swap');

        /* --- FUNDO ANIMADO PREMIUM --- */
        body {
            margin: 0;
            padding: 20px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: flex-start;
            font-family: 'Inter', sans-serif;
            /* Gradiente animado */
            background: linear-gradient(-45deg, #050505, #0d1a0d, #121212, #071a07);
            background-size: 400% 400%;
            animation: moveGradient 12s ease infinite;
            color: #ffffff;
            overflow-x: hidden;
        }

        @keyframes moveGradient {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        /* --- CABEÇALHO E PLACAR --- */
        header {
            text-align: center;
            margin-bottom: 20px;
            z-index: 10;
        }

        h1 {
            font-size: 1rem;
            letter-spacing: 5px;
            color: #28a745;
            margin-bottom: 10px;
            font-weight: 700;
            text-transform: uppercase;
            text-shadow: 0 0 15px rgba(40, 167, 69, 0.4);
        }

        .score-board {
            display: flex;
            gap: 20px;
            font-size: 0.8rem;
            color: rgba(255, 255, 255, 0.7);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .highlight { color: #fff; font-weight: 700; }

        /* --- CONTAINER DO JOGO (GRADE) --- */
        .game-container {
            width: 100%;
            max-width: 640px; /* Ajuste para caber 6 cartas de 100px + gaps */
            display: grid;
            grid-template-columns: repeat(6, 1fr); /* Grade de 6 colunas */
            gap: 10px;
            perspective: 1000px; /* Necessário para o efeito 3D */
            margin-bottom: 30px;
        }

        /* --- CARTAS E ANIMAÇÃO DE FLIP --- */
        .card {
            background-color: transparent;
            height: 100px; /* Altura fixa da carta */
            cursor: pointer;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            border-radius: 12px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.3);
        }

        /* Estado 'virado' da carta */
        .card.flip {
            transform: rotateY(180deg);
            cursor: default;
        }

        /* Estado 'combinado' (par encontrado) */
        .card.match {
            transform: rotateY(180deg) scale(0.95);
            opacity: 0.6;
            cursor: default;
            box-shadow: 0 0 10px rgba(40, 167, 69, 0.5);
        }

        /* Frente e Verso da Carta */
        .card-front, .card-back {
            width: 100%;
            height: 100%;
            position: absolute;
            border-radius: 12px;
            backface-visibility: hidden; /* Esconde a face oposta */
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Frente (onde fica a imagem) */
        .card-front {
            background-color: #1a1a1a;
            transform: rotateY(180deg); /* Começa virada para trás */
        }

        .card-front img {
            width: 100%;
            height: 100%;
            object-fit: cover; /* Faz a imagem preencher a carta */
        }

        /* Verso (capa da carta) */
        .card-back {
            background: rgba(255, 255, 255, 0.03);
            backdrop-filter: blur(5px);
            color: #28a745;
            font-size: 2rem;
            font-weight: 700;
        }

        /* --- BOTÃO REINICIAR --- */
        .btn-restart {
            background: transparent;
            color: #28a745;
            padding: 12px 30px;
            border: 2px solid #28a745;
            border-radius: 100px;
            font-weight: 700;
            cursor: pointer;
            font-size: 12px;
            letter-spacing: 2px;
            transition: all 0.3s ease;
            text-transform: uppercase;
            z-index: 10;
        }

        .btn-restart:hover {
            background: #28a745;
            color: #fff;
            box-shadow: 0 0 20px rgba(40, 167, 69, 0.5);
        }

        /* --- RESPONSIVIDADE PARA CELULAR --- */
        @media (max-width: 500px) {
            .game-container {
                grid-template-columns: repeat(4, 1fr); /* 4 colunas no celular (grade 4x9) */
                gap: 8px;
            }
            .card {
                height: 80px;
            }
        }
    </style>
</head>
